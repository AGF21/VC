# punsVC Discord Bot Configuration

# Discord Bot Token (get from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# punsVC Backend URL (the API server)
PUNSVC_API_BASE=http://localhost:8000

# Optional: API key for punsVC (if authentication is enabled)
# PUNSVC_API_KEY=your_api_key_here
